{
    "name": "cohete/skeleton",
    "description": "Skeleton project for Cohete async PHP framework",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "cohete/framework": "^0.1",
        "cohete/ddd": "^0.1",
        "react/mysql": "^0.7@dev",
        "bunny/bunny": "^0.6@alpha",
        "php-mcp/server": "^3.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/pascualmg/cohete-framework.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/pascualmg/cohete-ddd.git"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Pascual Munoz",
            "homepage": "https://pascualmg.dev"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
